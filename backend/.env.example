DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public"
JWT_SECRET="generate_a_long_random_string"
JWT_EXPIRES_IN="7d"
PORT=3001
NODE_ENV=production

# Comma-separated frontend origins allowed by CORS (add your Vercel URL after deploy)
CORS_ORIGIN="http://localhost:5173,https://your-app.vercel.app"

# AI provider — Google Gemini (required for live AI generation on Railway)
GEMINI_API_KEY="your_gemini_api_key"
GEMINI_MODEL="gemini-2.5-flash"
